# Domeniul vine din .env (STREAM_DOMAIN). DNS-ul lui trebuie să pointeze la
# IP-ul VPS-ului ÎNAINTE de primul start: Caddy cere certificatul de la Let's
# Encrypt la boot și eșuează dacă validarea HTTP nu trece.
{$STREAM_DOMAIN} {
	# Rate limiting: max 20 req/s per IP (plugin extern — vezi Caddy.Dockerfile)
	rate_limit {
		zone stream_limit {
			key    {remote_host}
			events 20
			window 1s
		}
	}

	# Reverse proxy către container-ul seby-tv-proxy.
	# flush_interval -1 = octeții pleacă imediat, fără buffering — obligatoriu
	# pentru pass-through-ul MPEG-TS, care e un răspuns fără sfârșit.
	reverse_proxy proxy:8080 {
		flush_interval -1
	}

	# Headere de securitate
	header {
		X-Content-Type-Options    nosniff
		X-Frame-Options           DENY
		Referrer-Policy           no-referrer
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		-Server
	}

	# Loguri de acces
	log {
		output file /data/access.log {
			roll_size 10mb
			roll_keep 3
		}
	}
}
